# PT 매니저 앱 환경변수 설정 가이드
# 
# Vercel 환경별 설정:
# - Production (main 브랜치): Supabase 프로덕션 프로젝트 URL/Key 사용
# - Preview (develop 브랜치): Supabase 개발 프로젝트 URL/Key 사용
#
# Vercel Dashboard > Settings > Environment Variables 에서 환경별로 설정하세요.

# Supabase 프로젝트 URL (예: https://xxxxx.supabase.co)
VITE_SUPABASE_URL = "https://your-project-ref.supabase.co"

# Supabase 퍼블릭 anon 키
VITE_SUPABASE_ANON_KEY = "your-anon-key-here"

# 카카오 REST API 키 (카카오 로그인용)
VITE_KAKAO_REST_API_KEY = "your-kakao-rest-api-key-here"
