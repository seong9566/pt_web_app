# PT 매니저 앱 (FitLink) 환경변수
#
# 사용법:
#   1. 이 파일을 복사하여 .env.local 생성: cp .env.example .env.local
#   2. 아래 값을 실제 키로 교체
#   3. .env.local은 Git에 추적되지 않음 (.gitignore 등록됨)
#
# Vercel 배포 시:
#   Vercel Dashboard > Settings > Environment Variables 에서 동일 변수를 설정하세요.
#   develop → Preview, main → Production 으로 자동 배포됩니다.

# Supabase 프로젝트 URL (예: https://xxxxx.supabase.co)
VITE_SUPABASE_URL = "https://your-project-ref.supabase.co"

# Supabase 퍼블릭 anon 키
VITE_SUPABASE_ANON_KEY = "your-anon-key-here"

# 카카오 REST API 키 (카카오톡 공유 기능용)
VITE_KAKAO_REST_API_KEY = "your-kakao-rest-api-key-here"
